<div
  class="rd-trending page-width"
  data-section-id="{{ section.id }}"
>
  <div class="rd-trending__inner">

    {%- comment -%} ── LEFT ── {%- endcomment -%}
    <div class="rd-trending__left">
      {%- if section.settings.eyebrow != blank -%}
        <p class="rd-trending__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="rd-trending__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <ul class="rd-trending__list" role="list">
        {%- for block in section.blocks -%}
          {%- assign col = block.settings.collection -%}
          <li
            class="rd-trending__item{% if forloop.first %} is-active{% endif %}"
            data-rd-index="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            <button
              class="rd-trending__link"
              type="button"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
              {% if col != blank %}data-col-url="{{ col.url }}"{% endif %}
            >
              <span>
                {%- if col != blank -%}
                  {{ col.title }}
                {%- else -%}
                  Sample collection
                {%- endif -%}
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </button>
          </li>
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} ── RIGHT ── {%- endcomment -%}
    <div class="rd-trending__right">
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        {%- assign product = col.products.first -%}
        <div
          class="rd-trending__panel{% if forloop.first %} is-active{% endif %}"
          data-rd-panel="{{ forloop.index0 }}"
        >
          {%- if product != blank -%}
            {%- liquid
              assign is_sale = false
              if product.metafields.custom.sale.value == true
                assign is_sale = true
              endif

              assign is_new = false
              assign new_days = section.settings.new_badge_days | default: 3
              assign new_seconds = new_days | times: 86400
              assign now_ts = 'now' | date: '%s' | plus: 0
              assign created_ts = product.created_at | date: '%s' | plus: 0
              assign age_seconds = now_ts | minus: created_ts
              if age_seconds < new_seconds
                assign is_new = true
              endif
            -%}
            <div class="rd-trending__card">
              <a href="{{ product.url }}" class="rd-trending__card-link" tabindex="-1" aria-hidden="true"></a>
              <div class="rd-trending__media">
                {%- if product.featured_media -%}
                  {{
                    product.featured_media
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '400, 600, 800',
                      sizes: '(max-width:749px) 100vw, 50vw',
                      alt: product.title,
                      class: 'rd-trending__img'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'rd-trending__img rd-trending__img--placeholder' }}
                {%- endif -%}

                <div class="rd-trending__badges">
                  {%- if is_new -%}
                    <span class="rd-trending__badge rd-trending__badge--new">New</span>
                  {%- endif -%}
                  {%- if is_sale -%}
                    <span class="rd-trending__badge rd-trending__badge--sale">Sale</span>
                  {%- endif -%}
                </div>

                <div class="rd-trending__actions">
                  <button
                    class="rd-trending__preview-btn"
                    type="button"
                    aria-label="Quick view {{ product.title | escape }}"
                    data-preview-img="{% if product.featured_media %}{{ product.featured_media | image_url: width: 450, height: 450 }}{% endif %}"
                    data-preview-title="{{ product.title | escape }}"
                    data-preview-url="{{ product.url }}"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  </button>
                  <button
                    class="rd-trending__wishlist-btn"
                    type="button"
                    aria-label="Add {{ product.title | escape }} to wishlist"
                    data-product-title="{{ product.title | escape }}"
                  >
                    <picture class="rd-trending__wishlist-icon">
                      <source
                        media="(min-width: 750px)"
                        srcset="{{ 'wishlist-heart-desktop.svg' | asset_url }}"
                      >
                      <img
                        src="{{ 'wishlist-heart-mobile.svg' | asset_url }}"
                        alt=""
                        width="18"
                        height="18"
                        loading="lazy"
                      >
                    </picture>
                  </button>
                </div>
              </div>

              <a href="{{ product.url }}" class="rd-trending__info">
                <span class="rd-trending__product-title">{{ product.title }}</span>
                <span class="rd-trending__product-price">
                  {%- if product.compare_at_price > product.price -%}
                    <span class="rd-trending__price-current">{{ product.price | money }}</span>
                    <s class="rd-trending__price-compare">{{ product.compare_at_price | money }}</s>
                  {%- else -%}
                    <span class="rd-trending__price-current">{{ product.price | money }}</span>
                  {%- endif -%}
                </span>
              </a>
            </div>
          {%- else -%}
            <div class="rd-trending__card rd-trending__card--placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'rd-trending__img rd-trending__img--placeholder' }}
              <div class="rd-trending__info">
                <span class="rd-trending__product-title">Sample product</span>
                <span class="rd-trending__product-price">
                  <span class="rd-trending__price-current">{{ 1999 | money }}</span>
                </span>
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<div class="rd-wishlist-toast" id="rd-wishlist-toast-{{ section.id }}" role="status" aria-live="polite">
  <div class="rd-wishlist-toast__inner">
    <svg class="rd-wishlist-toast__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    <p class="rd-wishlist-toast__text"></p>
    <button class="rd-wishlist-toast__close" type="button" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
</div>

<div class="rd-preview-overlay" id="rd-preview-overlay-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Product preview" aria-hidden="true">
  <div class="rd-preview-overlay__backdrop"></div>
  <div class="rd-preview-overlay__content">
    <button class="rd-preview-overlay__close" type="button" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    <div class="rd-preview-overlay__img-wrap">
      <img class="rd-preview-overlay__img" src="" alt="" width="450" height="450" loading="lazy">
    </div>
    <a class="rd-preview-overlay__cta" href="#">View product</a>
  </div>
</div>

<script>
  (function init() {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) {
      document.addEventListener('DOMContentLoaded', init, { once: true });
      return;
    }

    var items  = Array.from(section.querySelectorAll('.rd-trending__item'));
    var panels = Array.from(section.querySelectorAll('.rd-trending__panel'));
    var toast     = document.getElementById('rd-wishlist-toast-{{ section.id }}');
    var toastText = toast ? toast.querySelector('.rd-wishlist-toast__text') : null;
    var toastTimer = null;
    var overlay   = document.getElementById('rd-preview-overlay-{{ section.id }}');
    var overlayImg = overlay ? overlay.querySelector('.rd-preview-overlay__img') : null;
    var overlayCta = overlay ? overlay.querySelector('.rd-preview-overlay__cta') : null;

    /* ── Collection switcher ── */
    function activate(index) {
      items.forEach(function (item, i) {
        var active = i === index;
        item.classList.toggle('is-active', active);
        item.querySelector('button').setAttribute('aria-pressed', String(active));
      });
      panels.forEach(function (panel, i) {
        panel.classList.toggle('is-active', i === index);
      });
    }

    items.forEach(function (item, index) {
      var btn = item.querySelector('button');
      btn.addEventListener('mouseenter', function () { activate(index); });
      btn.addEventListener('click', function () {
        var url = btn.dataset.colUrl;
        if (url) window.location.href = url;
      });
    });

    /* ── Wishlist toast ── */
    function showToast(productTitle) {
      if (!toast || !toastText) return;
      toastText.textContent = '\u201C' + productTitle + '\u201D has been added to your wishlist.';
      toast.classList.add('is-visible');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function () {
        toast.classList.remove('is-visible');
      }, 4000);
    }

    if (toast) {
      var closeBtn = toast.querySelector('.rd-wishlist-toast__close');
      if (closeBtn) {
        closeBtn.addEventListener('click', function () {
          toast.classList.remove('is-visible');
          clearTimeout(toastTimer);
        });
      }
    }

    section.addEventListener('click', function (e) {
      var wishlistBtn = e.target.closest('.rd-trending__wishlist-btn');
      if (wishlistBtn) {
        e.preventDefault();
        e.stopPropagation();
        wishlistBtn.classList.toggle('is-active');
        showToast(wishlistBtn.dataset.productTitle || '');
        return;
      }
      var previewBtn = e.target.closest('.rd-trending__preview-btn');
      if (previewBtn) {
        e.preventDefault();
        e.stopPropagation();
        var imgSrc = previewBtn.getAttribute('data-preview-img') || '';
        var title = previewBtn.getAttribute('data-preview-title') || '';
        var url = previewBtn.getAttribute('data-preview-url') || '#';
        if (overlayImg) overlayImg.src = imgSrc;
        if (overlayImg) overlayImg.alt = title;
        if (overlayCta) overlayCta.href = url;
        overlay.classList.add('is-visible');
        overlay.removeAttribute('aria-hidden');
        document.body.style.overflow = 'hidden';
      }
    });

    function closePreview() {
      if (!overlay) return;
      overlay.classList.remove('is-visible');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    if (overlay) {
      overlay.querySelector('.rd-preview-overlay__close').addEventListener('click', closePreview);
      overlay.querySelector('.rd-preview-overlay__backdrop').addEventListener('click', closePreview);
    }
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay && overlay.classList.contains('is-visible')) closePreview();
    });
  })();
</script>

{{ 'rd-section.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "RD Trending Collections",
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Best sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trending Products"
    },
    {
      "type": "header",
      "content": "Product badges"
    },
    {
      "type": "range",
      "id": "new_badge_days",
      "label": "Show 'New' badge for (days)",
      "info": "Badge appears on products added within this many days. Set to 0 to disable.",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "RD Trending Collections",
      "category": "RD"
    }
  ]
}
{% endschema %}
